---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Vinu Varghese">
  <main class="relative min-h-svh flex flex-col items-center justify-center px-6">
    <div class="absolute inset-0 blueprint" aria-hidden="true"></div>

    <div class="relative max-w-xl w-full">
      <p class="font-mono text-xs text-copper dark:text-copper-bright mb-6">
        <span class="opacity-60">vinu@vinuvarghese.com:~$</span> cat requested-page
      </p>
      <h1 class="text-7xl md:text-9xl font-bold tracking-tighter mb-6">
        404<span class="text-copper dark:text-copper-bright">.</span>
      </h1>
      <p class="font-mono text-sm text-stone-500 dark:text-stone-400 mb-10">
        cat: requested-page: No such file or directory
      </p>
      <a
        href="/"
        class="inline-block font-mono text-sm border border-ink/20 dark:border-white/20 px-5 py-3 hover:border-copper hover:text-copper dark:hover:border-copper-bright dark:hover:text-copper-bright transition-colors"
      >
        $ cd ~
      </a>
    </div>
  </main>
</Layout>
