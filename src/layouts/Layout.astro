---
import '../index.css';
import Footer from '../components/Footer';

const {
  title = 'Vinu Varghese | Technical Architect - Cloud & AI Solutions Expert',
  description = 'Vinu Varghese - Technical Architect with 20+ years of experience in cloud computing (AWS, Azure), artificial intelligence, and full-stack enterprise solutions. Expert in digital transformation, microservices, and scalable system design.',
} = Astro.props;

const siteUrl = 'https://www.vinuvarghese.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const measurementId = 'G-39XTPTVSMS';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: 'Vinu Varghese',
      url: siteUrl,
      image: `${siteUrl}/og-image.png`,
      description,
      jobTitle: 'Technical Architect',
      worksFor: {
        '@type': 'Organization',
        name: 'Xminds Infotech Pvt Ltd',
      },
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'University of Kerala',
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Thiruvananthapuram',
        addressRegion: 'Kerala',
        addressCountry: 'IN',
      },
      email: 'vinu@vinuvarghese.com',
      sameAs: [
        'https://www.linkedin.com/in/vinuvarghese/',
        'https://github.com/vinu',
        'https://stackoverflow.com/users/674067/jang00',
      ],
      knowsAbout: [
        'Cloud Architecture',
        'AWS',
        'Azure',
        'Artificial Intelligence',
        'Machine Learning',
        'Microservices',
        'Full-Stack Development',
        'DevOps',
        'Enterprise Architecture',
        'Digital Transformation',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Vinu Varghese',
      publisher: { '@id': `${siteUrl}/#person` },
      inLanguage: 'en',
    },
    {
      '@type': 'ProfilePage',
      '@id': canonicalUrl,
      url: canonicalUrl,
      name: title,
      isPartOf: { '@id': `${siteUrl}/#website` },
      mainEntity: { '@id': `${siteUrl}/#person` },
      inLanguage: 'en',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth scroll-pt-20">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function() {
        document.documentElement.classList.add('js');
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (stored !== 'light' && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Vinu Varghese" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#f5f2ea" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#100f0d" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Vinu Varghese" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vinu Varghese - Technical Architect" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics -->
    <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script type="text/partytown" define:vars={{ measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', measurementId);
    </script>
  </head>
  <body class="bg-paper text-ink dark:bg-night dark:text-stone-200 font-sans antialiased transition-colors duration-300">
    <slot />
    <Footer />
  </body>
</html>
